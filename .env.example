# Copy this file to .env and fill in real values. Never commit .env.

# --- MSSQL container ---
# SA password must satisfy SQL Server's policy: 8+ chars, with upper, lower, digit/symbol.
MSSQL_SA_PASSWORD=ChangeMe_Strong_Pwd_123!

# --- Backend ---
PORT=3000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
BCRYPT_ROUNDS=12

DB_SERVER=localhost
DB_PORT=1433
DB_NAME=appointments
DB_NAME_TEST=appointments_test
DB_USER=sa
DB_PASSWORD=ChangeMe_Strong_Pwd_123!

# Set this on first migrate to seed the initial secretary user.
INITIAL_SECRETARY_PASSWORD=changeme

# Leave EMPLOYEE_API_URL unset to run with the manual-entry fallback only.
EMPLOYEE_API_URL=
EMPLOYEE_API_KEY=

CORS_ORIGIN=http://localhost:5173

# --- Frontend (read at build time by Vite) ---
VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000
