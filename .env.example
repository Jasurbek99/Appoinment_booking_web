# Copy this file to .env and fill in real values. Never commit .env.
# For production, copy to .env.production and override the marked values.

# --- Database mode ---
# Two options for the appointments database:
#
# 1) Bundled MSSQL container (default for fresh deployments without a DB)
#    Set COMPOSE_PROFILES=bundled-db, fill MSSQL_SA_PASSWORD below, and leave
#    DB_SERVER=mssql so the backend connects to the container by service name.
#
# 2) External / production MSSQL (recommended when one exists)
#    Leave COMPOSE_PROFILES empty (no bundled container starts), set
#    DB_SERVER to the prod DB hostname or IP, and set DB_USER/DB_PASSWORD
#    to credentials that exist on that server. MSSQL_SA_PASSWORD is unused.
#
COMPOSE_PROFILES=bundled-db

# --- MSSQL container (only used when COMPOSE_PROFILES=bundled-db) ---
# SA password must satisfy SQL Server's policy: 8+ chars, with upper, lower, digit/symbol.
MSSQL_SA_PASSWORD=ChangeMe_Strong_Pwd_123!

# --- Backend ---
PORT=3000
NODE_ENV=development                # set to "production" in .env.production

# REQUIRED in prod: replace with a random 32+ char string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
BCRYPT_ROUNDS=12

# DB_SERVER: container hostname when bundled, prod IP/hostname when external.
#   Bundled  → DB_SERVER=mssql
#   External → DB_SERVER=10.0.0.42  (or whatever your prod DB address is)
DB_SERVER=mssql
DB_PORT=1433
DB_NAME=appointments
DB_NAME_TEST=appointments_test
DB_USER=sa
DB_PASSWORD=ChangeMe_Strong_Pwd_123!

# Set this on first migrate to seed the initial secretary user.
INITIAL_SECRETARY_PASSWORD=changeme

# Employees directory database (HR data). In dev you may point this at the same
# MSSQL instance; in prod it is typically a read-only account on the HR DB.
EMPLOYEE_DB_SERVER=localhost
EMPLOYEE_DB_PORT=1433
EMPLOYEE_DB_NAME=hr
EMPLOYEE_DB_USER=sa
EMPLOYEE_DB_PASSWORD=ChangeMe_Strong_Pwd_123!

# Comma-separated allowed origins. Leave EMPTY for same-origin deployment
# behind nginx (frontend and backend share a hostname) — disables CORS entirely.
# Otherwise list each origin: CORS_ORIGIN=https://app.example.com,https://staff.example.com
CORS_ORIGIN=http://localhost:5173

# Number of trusted reverse-proxy hops in front of Express.
# 0 = no proxy (dev), 1 = one nginx in front (typical prod), etc.
# Required for correct req.ip and Secure cookie behavior behind a proxy.
TRUST_PROXY=0

# pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Maximum JSON body size. Override only if you actually need larger payloads.
BODY_LIMIT=100kb

# --- Frontend (read at build time by Vite) ---
# Leave EMPTY for same-origin deployment — the frontend calls relative URLs
# and nginx routes /api and /socket.io to the backend.
VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000

# Host port the frontend (nginx) container binds to. Default 8088 to leave
# 80/443 free for a host TLS terminator. Check what's free on your box:
#   sudo ss -tuln
# Then set this to any free port (e.g. 80, 8088, 8443, etc.).
FRONTEND_PORT=8088
