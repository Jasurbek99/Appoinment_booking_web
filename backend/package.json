{
  "name": "appointment-booking-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch --env-file=../.env src/server.js",
    "start": "node --env-file=../.env src/server.js",
    "migrate": "node --env-file=../.env src/db/migrate.js",
    "migrate:test": "node --env-file=../.env src/db/migrate.js --test",
    "seed": "node --env-file=../.env src/db/seed.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie": "^0.6.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^11.0.1",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "supertest": "^7.0.0",
    "vitest": "^1.6.0"
  }
}
